# Christina's Child Care Center - Environment Variables
# Copy this file to .env.local and fill in your values.

# Anthropic API Key for AI Lesson Generation
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Demo Mode — set to 'true' to show demo credential panels on login pages
NEXT_PUBLIC_DEMO_MODE=false

# Session signing secret — generate with: openssl rand -hex 32
# Used to HMAC-sign the auth_session cookie in the fallback (no-Supabase) auth path.
# Must be the same value across all server instances. Change this in production.
SESSION_SECRET=dev-secret-change-in-production

# Resend API Key for transactional email
RESEND_API_KEY=your_resend_api_key_here

# ElevenLabs TTS (used by video pipeline scripts)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# D-ID Avatar Generation (used by video pipeline scripts)
DID_API_KEY=your_did_api_key_here

# Sentry Error Monitoring
# Get this from your Sentry project at sentry.io → Project Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here
